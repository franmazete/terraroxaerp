# ════════════════════════════════════════════════════════════════════
# COPIE PARA .env.local E PREENCHA OS VALORES REAIS
# Stack: Next.js 15. Variáveis públicas precisam do prefixo NEXT_PUBLIC_
# (NÃO use VITE_ — esse prefixo é do Vite, ignorado pelo Next.js).
# ════════════════════════════════════════════════════════════════════

# ─── Supabase (cliente — vai pro browser) ───────────────────────────
# Settings → API no Supabase Studio
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...sua_anon_key_aqui

# ─── Supabase (server — NUNCA expor ao browser) ────────────────────
# Service Role: dá acesso total ao banco (bypass de RLS). Só usar em
# Server Actions/Route Handlers, NUNCA em "use client".
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...sua_service_role_aqui

# Connection string direta (porta 5432, NÃO o pooler 6543) — usada pelo
# CLI para aplicar migrations. Settings → Database → Connection string → URI
# Se a senha do banco tiver caractere especial (@, #, ?, etc.) você
# precisa URL-encodar (@ → %40, # → %23 etc.)
SUPABASE_DB_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres
